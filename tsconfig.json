{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": [
      "./worker-configuration.d.ts",
      "vite/client"
    ],
    "strict": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@web/*": ["./src/web/*"],
      "@shared/*": ["./ts/shared/*"]
    }
  },
  "include": [
    "ts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.web.config.ts",
    "worker-configuration.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
